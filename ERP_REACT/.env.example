# ERP React - Environment Variables
# Copy to .env for local development

# Database (shared with Streamlit version)
DATABASE_URL=postgresql://user:pass@host:5432/constructo_ai

# JWT Authentication (REQUIRED in production — Render auto-generates this)
ERP_JWT_SECRET=your-secure-random-string-here

# Environment (set to "production" on Render)
ENVIRONMENT=development

# Development mode (set to "true" to restrict access to super-admin only)
ERP_DEV_MODE=false

# App base URL (used for Stripe redirect URLs)
APP_BASE_URL=http://localhost:8003

# Stripe (optional for local dev)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# SMTP - Transactional email (devis, notifications)
# GoDaddy: smtpout.secureserver.net / 465 / SSL
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Constructo AI
SMTP_USE_SSL=true

# Anthropic AI (optional for local dev)
ANTHROPIC_API_KEY=

# Admin
ADMIN_PASSWORD=

# Frontend (Vite — leave empty for monolithic deploy with relative URLs)
VITE_API_URL=
