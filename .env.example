# ============================================
# CONFIGURATION CONSTRUCTO AI — TEMPLATE
# ============================================
# Copiez ce fichier en .env et remplissez vos valeurs
# NE COMMITTEZ JAMAIS le fichier .env (contient des secrets)
#
# Pour générer un secret sûr :
#   python -c "import secrets; print(secrets.token_urlsafe(64))"

# ============================================
# SECRETS JWT — OBLIGATOIRES EN PRODUCTION
# ============================================
# Chacune des 3 apps a son propre secret JWT.
# En PRODUCTION : si non défini, l'app refuse de démarrer (RuntimeError).
# En DÉVELOPPEMENT : si non défini, une clé aléatoire est générée pour le
# processus en cours (les sessions ne survivront pas au redémarrage).

# ERP_REACT (port 8003 backend / 5174 frontend)
ERP_JWT_SECRET=

# MOBILE_REACT (port 8003 backend / 5175 frontend)
JWT_SECRET_KEY=

# SEAOP_REACT (port 8002 backend / 5173 frontend)
SEAOP_JWT_SECRET=

# ============================================
# BASE DE DONNÉES (Choisir UNE option)
# ============================================

# OPTION 1: PostgreSQL (RECOMMANDÉ pour production)
# ----------------------------------------------------
# Format: postgresql://username:password@host:port/database
# Obtenez cette URL depuis votre hébergeur PostgreSQL

# Exemple Supabase:
# DATABASE_URL=postgresql://postgres:votre_password@db.xxx.supabase.co:5432/postgres

# Exemple Neon:
# DATABASE_URL=postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb

# Exemple Railway:
# DATABASE_URL=postgresql://postgres:password@containers-us-west-xxx.railway.app:7431/railway

# Exemple Render:
# DATABASE_URL=postgresql://user:password@dpg-xxx.oregon-postgres.render.com/dbname

# Laissez vide pour utiliser SQLite (développement local)
DATABASE_URL=

# OPTION 2: Configuration PostgreSQL détaillée (alternative)
# -----------------------------------------------------------
# Utilisez ceci si vous préférez des variables séparées
# (DATABASE_URL a la priorité si les deux sont définis)

POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ============================================
# API CLAUDE (Intelligence Artificielle)
# ============================================

# Clé API Anthropic Claude (OBLIGATOIRE pour assistant IA)
# Obtenez votre clé sur: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OU (alternative)
CLAUDE_API_KEY=

# Modèle Claude à utiliser (optionnel - par défaut: claude-opus-4-7)
CLAUDE_MODEL=claude-opus-4-7

# ============================================
# SÉCURITÉ (Optionnel mais recommandé)
# ============================================

# Clé secrète pour sessions (générez avec: python generate_secret_key.py)
SECRET_KEY=

# Mots de passe administrateurs (NE PAS utiliser en production)
# A REMPLACER par systeme utilisateurs en base de donnees
ADMIN_PASSWORD=
DG_ADMIN_PASSWORD=
SUPERVISEUR_PASSWORD=
DIRECTION_PASSWORD=

# Mot de passe compte Constructo Admin (fallback env-only)
CONSTRUCTO_ADMIN_PASSWORD=

# Mot de passe compte production (fallback env-only)
PRODUCTION_PASSWORD=

# Hashes bcrypt des mots de passe (RECOMMANDE en production au lieu des mots de passe en clair)
# Generez avec: python -c "import bcrypt; print(bcrypt.hashpw(b'votre_mdp', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=
DG_ADMIN_PASSWORD_HASH=
SUPERVISEUR_PASSWORD_HASH=
DIRECTION_PASSWORD_HASH=
CONSTRUCTO_ADMIN_PASSWORD_HASH=
PRODUCTION_PASSWORD_HASH=

# Mot de passe admin par defaut pour nouveaux tenants (EXPERTS_AI)
ADMIN_DEFAULT_PASSWORD=

# Mot de passe par defaut pour super admin (creation utilisateurs)
DEFAULT_ADMIN_PASSWORD=

# Mot de passe par defaut pour compte Sylvain (modules/auth)
SYLVAIN_DEFAULT_PASSWORD=

# Mot de passe demo (EXPERTS_AI init_multitenant, ne pas utiliser en production)
# DEMO_PASSWORD=

# Cle secrete pour sessions persistantes (persistent_session.py)
SESSION_SECRET=

# Cle secrete pour chiffrement emails (modules/email_manager)
EMAIL_SECRET_KEY=

# ============================================
# CONFIGURATION APPLICATION
# ============================================

# Environnement (local, production, staging)
ENVIRONMENT=local

# Debug mode (True pour développement, False pour production)
DEBUG=True

# Port serveur (optionnel, 8501 pour Streamlit, 8000 pour API REST, 8100 pour MCP)
PORT=8501

# URL publique de l'application (prioritaire pour generation de liens)
# Exemple: https://votre-instance.example.com
APP_URL=

# URL de base utilisee pour les redirections OAuth/Stripe et les liens emails
# Exemple dev: http://localhost:5174
# Exemple prod: https://votre-instance.example.com
APP_BASE_URL=

# URL de connexion affichee dans les emails (vide = utilise APP_BASE_URL)
LOGIN_URL=

# Email de support affiche dans les emails
SUPPORT_EMAIL=

# ============================================
# STOCKAGE ET BACKUPS
# ============================================

# Chemin personnalise pour pieces jointes (optionnel)
ATTACHMENTS_PATH=

# Repertoire des pieces jointes (utilise par attachments_manager.py et dossier.py)
ATTACHMENTS_DIR=

# Chemin de donnees generique (fallback pour stockage fichiers)
DATA_PATH=

# Repertoire de donnees pour EXPERTS_AI (defaut: data)
DATA_DIR=data

# Chemin personnalise pour backups (optionnel)
BACKUP_PATH=

# Repertoire local pour backups (defaut: /opt/render/project/data/backups)
BACKUP_LOCAL_DIR=

# ============================================
# STRIPE PAYMENT PROCESSING (Optionnel)
# ============================================
# Pour activer les paiements en ligne
# Obtenez vos clés sur: https://dashboard.stripe.com/apikeys
#
# FORFAITS DISPONIBLES:
# - ERP Complet (159.99$/mois + taxes + credits IA prepayes): STRIPE_PRICE_ID
# - EXPERTS IA (49.99$/mois + taxes + credits IA prepayes): STRIPE_EXPERTS_IA_PRICE_ID

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=                    # Prix ERP Complet Constructo AI (159.99$/mois)
STRIPE_EXPERTS_IA_PRICE_ID=         # Prix EXPERTS IA seul (49.99$/mois)

# ============================================
# SENTRY ERROR MONITORING (Optionnel)
# ============================================
# Pour le suivi des erreurs en production
# Créez un projet sur: https://sentry.io/

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=

# Taux d'echantillonnage Sentry (0.0 a 1.0, defaut: 0.1 = 10%)
SENTRY_SAMPLE_RATE=0.1

# ============================================
# GITHUB BACKUPS (Optionnel)
# ============================================
# Pour sauvegarder automatiquement vers GitHub Releases
# Créez un token sur: https://github.com/settings/tokens

GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BACKUP_ENABLED=false

# Nombre de backups locaux a conserver (defaut: 5)
KEEP_LOCAL_BACKUPS=5

# Nombre de releases GitHub a conserver (defaut: 10)
KEEP_GITHUB_RELEASES=10

# Taille max des backups en Mo (defaut: 100)
MAX_BACKUP_SIZE_MB=100

# Intervalle de backup automatique en minutes (defaut: 120)
BACKUP_SCHEDULE_MINUTES=120

# Forcer un backup au demarrage (defaut: false)
FORCE_BACKUP_ON_START=false

# Mode debug pour les backups GitHub (defaut: false)
DEBUG_GITHUB_BACKUP=false

# ============================================
# EMAIL SMTP (Optionnel)
# ============================================
# Pour l'envoi d'emails (notifications, confirmations)

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_EMAIL_PASSWORD=

# ============================================
# API REST CONFIGURATION
# ============================================

# Clé secrète pour l'API (générée automatiquement sur Render)
API_SECRET_KEY=

# Limite de requêtes par heure (défaut: 1000)
RATE_LIMIT_DEFAULT=1000

# Origines CORS autorisées (séparées par virgules)
# Ajoutez votre domaine de production: https://votre-instance.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:8002,http://localhost:8003

# Domaines additionnels pour CSP connect-src (CSV)
# Exemple: https://votre-cdn.example.com https://*.stripe.com
CSP_CONNECT_SRC=

# ============================================
# DÉPLOIEMENT ET MIGRATIONS
# ============================================

# Ignorer les migrations au demarrage (defaut: false)
SKIP_STARTUP_MIGRATIONS=false

# Reinitialiser la base de donnees (DANGER - defaut: false)
RESET_DATABASE=false

# Forcer la migration de tous les tenants (defaut: false)
MIGRATE_ALL_TENANTS=false

# Signaler qu'une migration DB est necessaire (usage interne, defaut: false)
DB_MIGRATION_NEEDED=false

# Forcer la reparation de la base de donnees (defaut: false)
FORCE_DB_REPAIR=false

# Mot de passe super admin (OBLIGATOIRE en production)
DEFAULT_SUPER_ADMIN_PASSWORD=

# ============================================
# AI GUARD (Optionnel)
# ============================================
# IDs d'entreprise exemptes de la garde IA (virgules separees)
AI_GUARD_EXEMPT_IDS=

# Plafond de cout par pipeline IA en $ CAD (defaut: 5.00)
PIPELINE_COST_CEILING=5.00

# ============================================
# MCP SERVER (Optionnel)
# ============================================
# Configuration du serveur MCP (Model Context Protocol)

# Port du serveur MCP (defaut: 8100, utilise PORT en priorite)
MCP_PORT=8100

# Schema tenant pour le serveur MCP (ex: tenant_mon_entreprise)
MCP_TENANT_SCHEMA=

# ============================================
# C2B ADAPTER (Optionnel)
# ============================================
# Chemin vers le module C2B (defaut: ../C2B-main)
C2B_PATH=

# ============================================
# RENDER PLATFORM (Automatique)
# ============================================
# Ces variables sont automatiquement definies par Render
# Ne les definissez pas manuellement sauf en dev local

# RENDER=                          # Defini automatiquement sur Render (true)
# RENDER_EXTERNAL_URL=             # URL publique du service Render
# RENDER_DATABASE_URL=             # URL DB interne Render (prioritaire sur DATABASE_URL)
# RENDER_PERSISTENT_DISK_PATH=     # Chemin du disque persistant Render
# RENDER_SERVICE_ID=               # ID du service Render
# RENDER_GIT_COMMIT=               # Hash du commit Git deploye
# RENDER_DEPLOY_ID=                # ID du deploiement Render

# ============================================
# HUGGING FACE SPACES (Automatique)
# ============================================
# Ces variables sont automatiquement definies par Hugging Face
# Ne les definissez pas manuellement

# SPACE_ID=
# SPACE_HOST=
# SPACE_AUTHOR_NAME=
# SPACE_REPO_NAME=
# PERSISTENT_STORAGE_PATH=

# ============================================
# TESTS (Developpement uniquement)
# ============================================
# URL de base de donnees separee pour les tests d'integration
# TEST_DATABASE_URL=

# Test de backup immediat au demarrage (defaut: false)
# IMMEDIATE_BACKUP_TEST=false

# ============================================
# NOTES IMPORTANTES
# ============================================

# 1. SÉCURITÉ:
#    - Ne partagez JAMAIS ce fichier .env
#    - Ajoutez .env dans .gitignore
#    - Utilisez des secrets HF pour production

# 2. POSTGRESQL vs SQLITE:
#    - PostgreSQL: Production, >10 users, persistance garantie
#    - SQLite: Développement local, <10 users, simple

# 3. MIGRATION:
#    - Pour migrer SQLite → PostgreSQL: python migrate_to_postgres.py
#    - Consultez MIGRATION_GUIDE.md pour détails

# 4. SUPPORT:
#    - Documentation: README.md
#    - Issues: https://github.com/votre-repo/issues
#    - Email: info@constructoai.ca
